{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PoE Chat Assistant",
  "version": "0.1.0",
  "identifier": "com.hirahiragg.poe-chat-assistant",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PoE Chat Assistant",
        "width": 680,
        "height": 420,
        "minWidth": 500,
        "minHeight": 300,
        "decorations": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
