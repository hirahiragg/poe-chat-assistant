{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/v2/crates/tauri-cli/schema.json",
  "productName": "PoE Chat Assistant",
  "version": "0.1.0",
  "identifier": "com.hirahiragg.poe-chat-assistant",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PoE Chat Assistant",
        "width": 680,
        "height": 420,
        "minWidth": 500,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": null
    }
  }
}
